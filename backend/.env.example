# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/aiskin

# Auth
JWT_SECRET=change_this_to_a_secure_random_value
JWT_EXPIRES_IN=7d

# DashScope / Qwen compatible API
API_KEY=your_dashscope_api_key

# Aliyun OSS, optional. If unset, the backend falls back to local storage.
OSS_REGION=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_AUTHORIZATION_V4=false

